{
  "yf_period": "2y",
  "state_enabled": true,
  "always_notify": false,
  "max_message_length": 3500,
  "watchlist_default_group": "theme",
  "market_filter": {
    "enabled": true,
    "ticker": "^TWII",
    "name": "加權指數",
    "ma_period": 20,
    "min_ret20": -0.05,
    "volume_ratio_min": 0.8,
    "allow_when_not_bullish_if_strong_signal": true
  },
  "notify": {
    "top_n": 3,
    "min_setup_score": 5,
    "max_risk_score": 5,
    "min_ret5_pct": 5.0,
    "min_volume_ratio": 1.5,
    "require_any_signals": [
      "REBREAK",
      "SURGE",
      "EARLY"
    ],
    "push_rank_improvement_at_least": 1,
    "push_setup_change_at_least": 1,
    "priority_groups": [
      "theme"
    ]
  },
  "backtest": {
    "enabled": true,
    "period": "4y",
    "lookahead_days": [
      1,
      3,
      5
    ],
    "min_setup_score": 5,
    "max_risk_score": 5,
    "min_ret5_pct": 5.0,
    "min_volume_ratio": 1.5,
    "accepted_signals": [
      "REBREAK",
      "SURGE",
      "EARLY"
    ]
  },
  "group_weights": {
    "theme_bonus": 2,
    "core_penalty": 1,
    "etf_penalty": 3
  }
}