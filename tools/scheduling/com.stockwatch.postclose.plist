<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.stockwatch.postclose</string>

    <key>ProgramArguments</key>
    <array>
      <string>__REPO_ROOT__/tools/scheduling/stock-watch-postclose.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>14</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>__REPO_ROOT__/runs/scheduler/launchd-postclose.out.log</string>
    <key>StandardErrorPath</key>
    <string>__REPO_ROOT__/runs/scheduler/launchd-postclose.err.log</string>
  </dict>
</plist>

